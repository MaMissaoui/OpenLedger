# Copy to .env and adjust. Do not commit .env (it is gitignored).

# --- Postgres ---
POSTGRES_USER=openledger
POSTGRES_PASSWORD=change-me
POSTGRES_DB=openledger

# --- API ---
# For host-side dev, point at localhost:5432.
DATABASE_URL=postgres://openledger:change-me@localhost:5432/openledger?sslmode=disable
PORT=8090

# --- Domain (production) ---
# Your homelab domain. Traefik labels use openledger.<DOMAIN> as the router rule.
# Must match what homelab-auth is configured with.
DOMAIN=yourdomain.com

# --- Web (build-time, baked into the SPA bundle) ---
# Authelia portal URL used for sign-out link and 401 redirects.
VITE_AUTHELIA_PORTAL_URL=https://auth.yourdomain.com

# --- Seed (optional) ---
# LDAP UID and email for the demo book owner (must exist in lldap).
SEED_OWNER_LDAP_UID=admin
SEED_OWNER_EMAIL=admin@yourdomain.com
