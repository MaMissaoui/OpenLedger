# Copy to .env and adjust. Do not commit .env (it is gitignored).

# --- Postgres ---
POSTGRES_USER=openledger
POSTGRES_PASSWORD=openledger
POSTGRES_DB=openledger

# --- API ---
# Used by the api container; for host-side dev point at localhost:5432.
DATABASE_URL=postgres://openledger:openledger@localhost:5432/openledger?sslmode=disable
JWT_SECRET=dev-secret-change-me
PORT=8080

# --- Web ---
API_BASE_URL=http://localhost:8080
